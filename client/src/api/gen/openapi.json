          "content",
          "summary",
          "imageUrl"
        ]
      },
      "ShareResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "操作是否成功"
          },
          "message": {
            "type": "string",
            "description": "操作结果消息"
          },
          "data": {
            "type": "object",
            "description": "额外数据"
          }
        },
        "required": [
          "success",
          "message"
        ]
