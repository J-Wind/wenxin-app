        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "签文标题"
          },
          "content": {
            "type": "string",
            "description": "签文内容"
          },
          "summary": {
            "type": "string",
            "description": "深度解读摘要"
          },
          "imageUrl": {
            "type": "string",
            "description": "AI图片链接"
          }
        },
        "required": [
