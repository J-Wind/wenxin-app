        "required": [
          "mood"
        ]
      },
      "GenerateFortuneResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "生成是否成功"
          },
          "number": {
            "type": "string",
            "description": "签号"
          },
          "mainText": {
            "type": "string",
            "description": "主签文"
          },
          "culturalReference": {
            "type": "string",
            "description": "文化引用"
          },
          "hexagram": {
            "type": "string",
