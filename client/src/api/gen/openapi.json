          },
          "imageRatio": {
            "type": "string",
            "default": "1:1",
            "description": "图片比例",
            "enum": [
              "16:9",
              "3:2",
              "4:3",
              "1:1",
              "2:3",
              "9:16"
            ]
          }
        },
        "required": [
          "fortuneText"
        ]
      },
      "GenerateFortuneRequestDto": {
        "type": "object",
        "properties": {
          "mood": {
            "type": "string",
