{
  "$schema": "https://railway.app/railpack.schema.json",
  "build": {
    "commands": {
      "install": "npm install",
      "build": "./build-railway.sh"
    }
  },
  "start": "cd dist && NODE_ENV=production node server/main.js",
  "env": {
    "FORCE_AUTHN_INNERAPI_DOMAIN": "localhost",
    "NODE_ENV": "production"
  }
}
